{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "backend"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/createOrder", "function": "api" },
      { "source": "/verifyPayment", "function": "api" },
      { "source": "/extract-text", "function": "api" },
      { "source": "/**", "destination": "/index.html" }
    ]
  }
}
